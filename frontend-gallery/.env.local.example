# =============================================================================
# FRONTEND GALLERY - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# -----------------------------------------------------------------------------
# UNSPLASH API CONFIGURATION
# -----------------------------------------------------------------------------
# Get your access key from: https://unsplash.com/developers
# Create a new application and copy the "Access Key"
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# -----------------------------------------------------------------------------
# BACKEND API CONFIGURATION
# -----------------------------------------------------------------------------
# URL of the backend API (User Management API)
# For local development, this should point to your backend server
NEXT_PUBLIC_API_URL=http://localhost:9090/api

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# Number of images to load per page (infinite scroll)
NEXT_PUBLIC_IMAGES_PER_PAGE=20

# Enable debug mode (shows additional console logs)
NEXT_PUBLIC_DEBUG_MODE=false
