# =============================================================================
# BACKEND USERS API - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# Port on which the Express server will listen
PORT=9090

# Node environment: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# SQLite database file path (relative to project root)
# For production, consider PostgreSQL or MySQL with connection pooling
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens
# CRITICAL: Use a strong, random string in production (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT token expiration time
# Examples: 60 (60 seconds), "2 days", "10h", "7d"
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# SECURITY & RATE LIMITING
# -----------------------------------------------------------------------------
# Maximum number of login attempts per IP address per window
RATE_LIMIT_MAX_REQUESTS=5

# Time window for rate limiting (in minutes)
RATE_LIMIT_WINDOW_MINUTES=15

# CORS allowed origins (comma-separated for multiple origins)
# Use * for development only, specify exact origins in production
CORS_ORIGIN=http://localhost:3000,http://localhost:9090

# -----------------------------------------------------------------------------
# FILE UPLOAD CONFIGURATION
# -----------------------------------------------------------------------------
# Maximum file size for batch import (in bytes)
# 10MB = 10485760 bytes
MAX_FILE_SIZE=10485760

# Allowed file MIME types for upload
ALLOWED_FILE_TYPES=application/json

# -----------------------------------------------------------------------------
# LOGGING & MONITORING
# -----------------------------------------------------------------------------
# Log level: error | warn | info | debug
LOG_LEVEL=info

# Enable request logging (true/false)
ENABLE_REQUEST_LOGGING=true
