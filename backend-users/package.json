{
  "name": "backend-users",
  "version": "1.0.0",
  "description": "Enterprise-grade User Management API with authentication, batch import, and comprehensive security",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=tests/integration",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "api",
    "users",
    "authentication",
    "jwt",
    "express",
    "typescript"
  ],
  "author": "MARC-AURELE A. CHEGNIMONHAN (Benin Dev.) - Senior Full-Stack Developer",
  "license": "MIT",
  "dependencies": {
    "@faker-js/faker": "latest",
    "@prisma/adapter-better-sqlite3": "latest",
    "@prisma/client": "^7.8.0",
    "bcrypt": "latest",
    "better-sqlite3": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "jsonwebtoken": "latest",
    "multer": "latest",
    "swagger-jsdoc": "latest",
    "swagger-ui-express": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bcrypt": "latest",
    "@types/better-sqlite3": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jest": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/multer": "latest",
    "@types/node": "latest",
    "@types/supertest": "latest",
    "@types/swagger-jsdoc": "latest",
    "@types/swagger-ui-express": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "jest": "latest",
    "prettier": "latest",
    "prisma": "^7.8.0",
    "supertest": "latest",
    "ts-jest": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
