// =============================================================================
// PRISMA SCHEMA - USER MANAGEMENT DATABASE
// =============================================================================
// This schema defines the database structure for our user management system.
// We use SQLite for simplicity and portability, but this can easily be
// migrated to PostgreSQL or MySQL by changing the provider.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// =============================================================================
// USER MODEL
// =============================================================================
// Represents a user in the system with complete profile information
// and authentication credentials.
model User {
  // Primary key - Auto-incrementing integer ID
  id Int @id @default(autoincrement())

  // Personal Information
  firstName String // User's first name
  lastName  String // User's last name
  birthDate DateTime // Date of birth (stored as ISO date)

  // Location Information
  city    String // City of residence
  country String // ISO2 country code (e.g., FR, US, CI)

  // Visual Identity
  avatar String // URL to user's avatar image

  // Professional Information
  company     String // Company name where user works
  jobPosition String // Job title or position

  // Contact Information
  mobile String // Formatted phone number

  // Authentication Credentials
  // UNIQUE constraint ensures no duplicate usernames in the system
  username String @unique

  // UNIQUE constraint ensures no duplicate emails in the system
  email String @unique

  // Password is stored as bcrypt hash (NEVER store plain text passwords!)
  // The hash includes salt automatically, making rainbow table attacks ineffective
  password String

  // Authorization
  // Role determines what actions the user can perform in the system
  // "admin" = full access to all resources
  // "user" = limited access, can only view own profile
  role String @default("user") // Default role is "user"

  // Audit Timestamps
  // Automatically set when record is created
  createdAt DateTime @default(now())

  // Automatically updated whenever record is modified
  updatedAt DateTime @updatedAt

  // =============================================================================
  // INDEXES FOR PERFORMANCE OPTIMIZATION
  // =============================================================================
  // These indexes dramatically speed up common queries:

  // 1. Login queries search by email OR username
  @@index([email])
  @@index([username])
  // 2. Composite index for role-based queries (e.g., "get all admins")
  @@index([role])
  // 3. Index on createdAt for sorting users by registration date
  @@index([createdAt])
  // Table name in database will be "users" (lowercase, plural)
  @@map("users")
}

